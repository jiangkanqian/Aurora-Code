# OpenAI-compatible backend switch
CLAUDE_CODE_USE_OPENAI_COMPAT=1

# Required: API key for your OpenAI-compatible endpoint
OPENAI_API_KEY=your_api_key_here

# Optional: endpoint base url (must expose /v1/chat/completions)
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: clear proxy env vars for startup only (default: off)
# OPENAI_COMPAT_CLEAR_PROXY=0

# Required: model/deployment id your endpoint supports
ANTHROPIC_MODEL=gpt-4.1

# Optional: direct Anthropic-compatible fallback key (if needed)
# ANTHROPIC_API_KEY=
